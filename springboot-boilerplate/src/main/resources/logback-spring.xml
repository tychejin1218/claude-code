<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- Logback 색상, 공백 규칙 설정 -->
  <conversionRule conversionWord="clr"
    converterClass="org.springframework.boot.logging.logback.ColorConverter"/>
  <conversionRule conversionWord="wex"
    converterClass="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter"/>
  <conversionRule conversionWord="wEx"
    converterClass="org.springframework.boot.logging.logback.ExtendedWhitespaceThrowableProxyConverter"/>
  <!-- 콘솔 로그 패턴 -->
  <property name="CONSOLE_LOG_PATTERN"
    value="${CONSOLE_LOG_PATTERN:-%clr(%d{${LOG_DATEFORMAT_PATTERN:-yyyy-MM-dd HH:mm:ss.SSS}}){green} %clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}}"/>

  <!-- 파일 로그 패턴 -->
  <property name="FILE_LOG_PATTERN"
    value="${FILE_LOG_PATTERN:-%d{${LOG_DATEFORMAT_PATTERN:-yyyy-MM-dd HH:mm:ss.SSS}} ${LOG_LEVEL_PATTERN:-%5p} ${PID:- } --- [%15.15t] %-40.40logger{39} : %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}}"/>

  <!-- log file path -->
  <springProfile name="logging-type-file-relative">
    <property name="FILE_PATH" value="logs"/>
  </springProfile>
  <springProfile name="logging-type-file-absolute">
    <property name="FILE_PATH" value="/var/log/app"/>
  </springProfile>
  <!-- log file name -->
  <property name="LOG_FILE_NAME" value="api"/>

  <!-- Profile 별로 로그 타입을 설정 -->
  <springProfile name="logging-type-console">
    <appender name="PROFILE-APPENDER" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
        <pattern>${CONSOLE_LOG_PATTERN}</pattern>
      </encoder>
    </appender>
    <appender name="SIFT-APPENDER" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
        <pattern>${CONSOLE_LOG_PATTERN}</pattern>
      </encoder>
    </appender>
  </springProfile>
  <!-- 파일로 저장 -->
  <springProfile name="!logging-type-console">
    <appender name="PROFILE-APPENDER" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <!-- 파일경로 설정 -->
      <file>${FILE_PATH}/${LOG_FILE_NAME}.log</file>

      <!-- 출력패턴 설정 -->
      <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
        <pattern>${FILE_LOG_PATTERN}</pattern>
      </encoder>
      <!-- datadog Log collector 설정-->
      <!-- <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>-->
      <!-- Rolling 정책 -->
      <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
        <fileNamePattern>${FILE_PATH}/${LOG_FILE_NAME}.%d{yyyy-MM-dd}_%i.log.gz</fileNamePattern>
        <maxFileSize>100MB</maxFileSize>
        <maxHistory>30</maxHistory>
      </rollingPolicy>
    </appender>

    <!-- 특정 로거 별로 파일을 별도로 저장 해야할때 -->
    <!-- https://logback.qos.ch/manual/appenders.html#SiftingAppender -->
    <appender name="SIFT-APPENDER" class="ch.qos.logback.classic.sift.SiftingAppender">
      <discriminator>
        <key>logFileName</key>
        <defaultValue>sift</defaultValue>
      </discriminator>
      <sift>
        <appender name="FILE-${logFileName}" class="ch.qos.logback.core.rolling.RollingFileAppender">
          <file>${FILE_PATH}/${logFileName}.log</file>
          <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>${FILE_LOG_PATTERN}</pattern>
          </encoder>
          <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${FILE_PATH}/${logFileName}.%d{yyyy-MM-dd}_%i.log.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
          </rollingPolicy>
        </appender>
      </sift>
    </appender>
  </springProfile>

  <!-- Profile 별로 로그 레벨을 설정 -->
  <springProfile name="logging-level-local">
    <!--특정 패키지 로그 레벨 설정-->
    <property name="LOG_LEVEL_root" value="INFO"/>
    <property name="LOG_LEVEL_com.example.api" value="INFO"/>
    <property name="LOG_LEVEL_com.example.api.mapper" value="INFO"/>
    <property name="LOG_LEVEL_org.springframework" value="INFO"/>
    <property name="LOG_LEVEL_com.zaxxer.hikari" value="DEBUG"/>
    <property name="LOG_LEVEL_org.hibernate" value="INFO"/>
    <property name="LOG_LEVEL_org.hibernate.SQL" value="INFO"/>
    <property name="LOG_LEVEL_org.hibernate.orm.jdbc.bind" value="INFO"/>
  </springProfile>
  <springProfile name="logging-level-dev">
    <property name="LOG_LEVEL_root" value="INFO"/>
    <property name="LOG_LEVEL_com.example.api" value="DEBUG"/>
    <property name="LOG_LEVEL_com.example.api.mapper" value="DEBUG"/>
    <property name="LOG_LEVEL_org.springframework" value="INFO"/>
    <property name="LOG_LEVEL_com.zaxxer.hikari" value="INFO"/>
    <property name="LOG_LEVEL_org.hibernate" value="INFO"/>
    <property name="LOG_LEVEL_org.hibernate.SQL" value="DEBUG"/>
    <property name="LOG_LEVEL_org.hibernate.orm.jdbc.bind" value="TRACE"/>
  </springProfile>
  <springProfile name="logging-level-stg">
    <property name="LOG_LEVEL_root" value="INFO"/>
    <property name="LOG_LEVEL_com.example.api" value="INFO"/>
    <property name="LOG_LEVEL_com.example.api.mapper" value="INFO"/>
    <property name="LOG_LEVEL_org.springframework" value="INFO"/>
    <property name="LOG_LEVEL_com.zaxxer.hikari" value="INFO"/>
    <property name="LOG_LEVEL_org.hibernate" value="INFO"/>
    <property name="LOG_LEVEL_org.hibernate.SQL" value="INFO"/>
    <property name="LOG_LEVEL_org.hibernate.orm.jdbc.bind" value="INFO"/>
  </springProfile>
  <springProfile name="logging-level-prd">
    <property name="LOG_LEVEL_root" value="INFO"/>
    <property name="LOG_LEVEL_com.example.api" value="INFO"/>
    <property name="LOG_LEVEL_com.example.api.mapper" value="INFO"/>
    <property name="LOG_LEVEL_org.springframework" value="INFO"/>
    <property name="LOG_LEVEL_com.zaxxer.hikari" value="INFO"/>
    <property name="LOG_LEVEL_org.hibernate" value="INFO"/>
    <property name="LOG_LEVEL_org.hibernate.SQL" value="INFO"/>
    <property name="LOG_LEVEL_org.hibernate.orm.jdbc.bind" value="INFO"/>
  </springProfile>

  <!-- 로그 레벨 설정 -->
  <root level="${LOG_LEVEL_root}">
    <appender-ref ref="PROFILE-APPENDER"/>
  </root>

  <!-- com.example.api -->
  <logger name="com.example.api"
    level="${LOG_LEVEL_com.example.api}"
    additivity="false">
    <appender-ref ref="PROFILE-APPENDER"/>
  </logger>
  <logger name="com.example.api.mapper"
    level="${LOG_LEVEL_com.example.api.mapper}"
    additivity="false">
    <appender-ref ref="PROFILE-APPENDER"/>
  </logger>
  <!-- springframework -->
  <logger name="org.springframework"
    level="${LOG_LEVEL_org.springframework}"
    additivity="false">
    <appender-ref ref="PROFILE-APPENDER"/>
  </logger>
  <!-- hikari -->
  <logger name="com.zaxxer.hikari"
    level="${LOG_LEVEL_com.zaxxer.hikari}"
    additivity="false">
    <appender-ref ref="PROFILE-APPENDER"/>
  </logger>
  <!-- hibernate -->
  <logger name="org.hibernate"
    level="${LOG_LEVEL_org.hibernate}"
    additivity="false">
    <appender-ref ref="PROFILE-APPENDER"/>
  </logger>
  <logger name="org.hibernate.SQL"
    level="${LOG_LEVEL_org.hibernate.SQL}"
    additivity="false">
    <appender-ref ref="PROFILE-APPENDER"/>
  </logger>
  <logger name="org.hibernate.orm.jdbc.bind"
    level="${LOG_LEVEL_org.hibernate.orm.jdbc.bind}"
    additivity="false">
    <appender-ref ref="PROFILE-APPENDER"/>
  </logger>

</configuration>
